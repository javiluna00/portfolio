---
import Pill from "./Pill.astro";
import LinkedinIcon from "./icons/LinkedinIcon.astro";
import GithubIcon from "./icons/GithubIcon.astro";
import JaviPhoto from "./assets/images/javi.jpg";
import { Image } from "astro:assets";
import CVIcon from "./icons/CVIcon.astro";
const cvPath = "/CV_Javi_Luna.pdf";
---

<div id="hero-container" class="opacity-0"> <div class="w-full flex justify-between items-center mb-10">
        <div id="avatar" class="relative">
            <Image
                class="size-20 md:size-24 rounded-2xl border-2 border-purple-500/30 p-1 rotate-3 hover:rotate-0 transition-transform duration-500"
                src={JaviPhoto}
                alt="Javi Luna"
            />
            <div class="absolute -bottom-2 -right-2 size-6 bg-green-500 border-4 border-slate-950 rounded-full"></div>
        </div>

        <div id="cv-button">
            <a
                href={cvPath}
                download="CV_Javi_Luna.pdf"
                class="group text-white/90 bg-white/5 hover:bg-purple-600/20 border border-white/10 hover:border-purple-500/50 rounded-full px-6 py-3 flex gap-2 items-center transition-all backdrop-blur-md"
            >
                <CVIcon class="size-5 group-hover:animate-bounce" />
                <span class="text-xs font-bold uppercase tracking-widest">Descargar CV</span>
            </a>
        </div>
    </div>

    <div class="overflow-hidden">
        <h2 id="hero-title" class="text-4xl md:text-7xl font-black tracking-tighter leading-none">
            Hola, soy <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-indigo-300 to-purple-400 bg-[length:200%_auto] animate-gradient">Javi Luna</span>
        </h2>
    </div>

    <div id="hero-badge" class="mt-4">
        <Pill class="bg-green-500/10 border border-green-500/40 w-64">
            <span class="text-[10px] font-medium text-green-400 uppercase tracking-[0.2em]">Abierto a propuestas</span>
        </Pill>
    </div>

    <div class="max-w-[750px] mt-8">
        <p id="hero-description" class="text-xl md:text-3xl text-pretty leading-tight text-slate-400">
            <span class="text-white font-medium">Ingeniero Informático.</span> 
            Especializado en <span class="text-purple-400">arquitectura web</span> y 
            análisis mediante <span class="text-yellow-200">Data Science</span>.
        </p>
        
        <p id="hero-sub" class="text-md md:text-xl mt-6 text-slate-500 border-l-2 border-purple-500/30 pl-4">
            Resolución de problemas complejos con un enfoque en <span class="text-slate-300">rendimiento y algoritmos</span>.
        </p>
    </div>

    <footer id="hero-footer" class="w-full flex items-center gap-8 mt-12">
        <div class="flex gap-6">
            <a href="https://www.linkedin.com/in/javilunac" class="social-icon text-slate-500 hover:text-white transition-colors">
                <LinkedinIcon class="size-8" />
            </a>
            <a href="https://github.com/javiluna00" class="social-icon text-slate-500 hover:text-white transition-colors">
                <GithubIcon class="size-8" />
            </a>
        </div>
        <div class="h-[1px] flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
    </footer>
</div>

<style>
    .animate-gradient {
        animation: gradient 5s linear infinite;
    }
    @keyframes gradient {
        0% { bg-position: 0% center; }
        100% { bg-position: 200% center; }
    }
</style>

<script>
    import { gsap } from "gsap";

    const initHeroAnimation = () => {
        const container = document.querySelector("#hero-container");
        if (!container) return;

        // Limpiamos cualquier animación previa si usas View Transitions
        gsap.set(container, { opacity: 0 });

        const tl = gsap.timeline({ 
            defaults: { ease: "power4.out" } 
        });

        tl.to(container, { 
            opacity: 1, 
            duration: 0.4 
        })
        .from("#avatar", { 
            scale: 0, 
            rotation: -45, 
            duration: 1, 
            ease: "elastic.out(1, 0.7)" 
        }, "-=0.2")
        .from("#hero-title", { 
            y: 50, 
            opacity: 0,
            skewY: 3, 
            duration: 0.8 
        }, "-=0.6")
        .from("#hero-badge", { 
            x: -20, 
            opacity: 0, 
            duration: 0.6 
        }, "-=0.5")
        .from("#hero-description", { 
            y: 20, 
            opacity: 0, 
            duration: 0.8 
        }, "-=0.5")
        .from("#hero-sub", { 
            x: -10, 
            opacity: 0, 
            duration: 0.8 
        }, "-=0.6")
        .from("#cv-button", { 
            scale: 0.9, 
            opacity: 0, 
            duration: 0.6 
        }, "-=0.8")
        .from(".social-icon", { 
            y: 10, 
            opacity: 0, 
            duration: 0.5, 
            stagger: 0.1 
        }, "-=0.4");
    };

    // Esto cubre carga normal y navegaciones de Astro
    document.addEventListener('DOMContentLoaded', initHeroAnimation);
    document.addEventListener('astro:page-load', initHeroAnimation);
</script>