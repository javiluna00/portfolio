---
import Pill from "./Pill.astro";

const { education, index } = Astro.props;
---

<div class="group relative w-full">
    <section
        class="relative flex flex-col justify-start items-start gap-y-3 px-6 py-4 w-full transition-all duration-300 group-hover:bg-white/[0.02] rounded-2xl"
    >
        <Pill
            class="bg-white text-zinc-950 font-bold px-3 py-1 text-[11px] uppercase tracking-wider shadow-lg"
        >
            <span data-i18n={`education.${index}.date`}>{education.date}</span>
        </Pill>

        <h4 data-i18n={`education.${index}.title`} class="text-2xl md:text-3xl font-bold text-white tracking-tight mt-1">
            {education.title}
        </h4>

        <span class={`${education.placeColor} text-lg md:text-xl font-medium italic opacity-90`}>
            {education.place}
        </span>

        <p data-i18n={`education.${index}.description`} class="text-slate-400 text-base md:text-lg leading-relaxed text-pretty max-w-[65ch]">
            {education.description}
        </p>

        {
            education.logos && (
                <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-3 p-3 bg-white/5 border border-white/10 rounded-xl backdrop-blur-sm group-hover:border-white/20 transition-colors">
                    {education.logos.map((logo) => (
                        <img
                            class="h-8 md:h-10 object-contain brightness-100 grayscale-[0.5] group-hover:grayscale-0 transition-all duration-500"
                            src={logo}
                            alt={`Logo de la institución`}
                        />
                    ))}
                </div>
            )
        }
    </section>
</div>

<style>
    .group:hover h4 {
        background: linear-gradient(to right, #fff, #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>
