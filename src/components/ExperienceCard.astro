---
import Pill from "./Pill.astro";

const { experience } = Astro.props;
---

<div class="group relative flex gap-x-5 transition-all duration-500">
    <div class="flex flex-col w-full pb-10">
        <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] font-bold uppercase tracking-widest text-purple-400 bg-purple-500/10 px-2 py-1 rounded-md border border-purple-500/20">
                {experience.duration}
            </span>
        </div>

        <div class="flex flex-col md:flex-row md:items-baseline gap-x-3 gap-y-1">
            <h3 class="text-xl md:text-2xl font-bold text-white tracking-tight">
                {experience.title}
            </h3>
            {experience.where && (
                <span class="text-indigo-300/90 font-medium text-lg md:text-xl italic">
                    @ {experience.where}
                </span>
            )}
        </div>

        <p class="mt-4 text-slate-400 text-base md:text-lg leading-relaxed max-w-[65ch] text-pretty">
            {experience.description}
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-4">
            {experience.logo && (
                <div class="p-1 bg-white rounded-lg shadow-sm group-hover:scale-110 transition-transform duration-300">
                    <img
                        class="h-8 w-auto object-contain"
                        src={experience.logo}
                        alt={`Logo de ${experience.where}`}
                    />
                </div>
            )}

            {experience.skills && (
                <div class="flex flex-wrap gap-2">
                    {experience.skills.map((skill) => (
                        <Pill class="bg-slate-800/50 border border-slate-700 hover:border-purple-500/50 hover:bg-slate-800 transition-colors cursor-default">
                            <span class="text-[11px] font-semibold text-slate-300 group-hover:text-purple-200 uppercase tracking-wider">
                                {skill}
                            </span>
                        </Pill>
                    ))}
                </div>
            )}
        </div>
    </div>
</div>

<style>
    /* Efecto de resaltado suave al pasar el ratón por la sección padre */
    .group:hover h3 {
        color: #c084fc; /* purple-400 */
        transition: color 0.3s ease;
    }
</style>