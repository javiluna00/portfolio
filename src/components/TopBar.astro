<header id="main-header" class="fixed top-0 left-0 right-0 z-[100] w-full py-6 pointer-events-none">
    <nav class="mx-auto w-fit px-6 py-3 rounded-full border border-white/10 bg-black/20 backdrop-blur-xl shadow-2xl flex justify-center items-center gap-x-5 md:gap-x-10 text-xs md:text-sm font-medium pointer-events-auto">
        <a class="nav-link relative text-white/70 hover:text-white transition-colors" href="#sobremi">Sobre mí</a>
        <a class="nav-link relative text-white/70 hover:text-white transition-colors" href="#educacion">Educación</a>
        <a class="nav-link relative text-white/70 hover:text-white transition-colors" href="#experiencia">Experiencia</a>
        <a class="nav-link relative text-white/70 hover:text-white transition-colors" href="#proyectos">Proyectos</a>
    </nav>
</header>

<style>
    /* Línea inferior */
    .nav-link::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: -4px;
        left: 0;
        background-color: #a855f7;
        transition: width 0.3s ease;
    }
    .nav-link:hover::after {
        width: 100%;
    }

    /* Cambio de tamaño al hacer scroll */
    .header-scrolled {
        padding-top: 1rem !important;
        padding-bottom: 1rem !important;
    }
    .header-scrolled nav {
        background-color: rgba(0, 0, 0, 0.5);
        border-color: rgba(255, 255, 255, 0.2);
        scale: 0.95;
        transition: all 0.4s ease;
    }
</style>

<script>
    import { gsap } from "gsap";

    const initHeader = () => {
        const header = document.querySelector("#main-header");
        if (!header) return;

        // Aseguramos que sea visible desde el inicio por si falla el script
        gsap.set(header, { y: -100, opacity: 0 });

        // Animación de entrada
        gsap.to(header, {
            y: 0,
            opacity: 1,
            duration: 1,
            ease: "power4.out",
            delay: 0.2
        });

        // Control de scroll (CSS Class)
        window.addEventListener("scroll", () => {
            if (window.scrollY > 50) {
                header.classList.add("header-scrolled");
            } else {
                header.classList.remove("header-scrolled");
            }
        });
    };

    // Ejecutar en carga y en cambios de página de Astro
    document.addEventListener('DOMContentLoaded', initHeader);
    document.addEventListener('astro:page-load', initHeader);
</script>