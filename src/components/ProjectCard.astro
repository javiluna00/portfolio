---
import { Image } from "astro:assets";
import GithubIcon from "./icons/GithubIcon.astro";
import ExternalLinkIcon from "./icons/ExternalLinkIcon.astro"; // Crea este o usa uno similar
import CVIcon from "./icons/CVIcon.astro";

const { project } = Astro.props;
---

<article class="group relative flex flex-col md:flex-row gap-8 items-center">
    <div class="w-full md:w-1/2 flex flex-col gap-y-4">
        <div class="flex items-center gap-x-3">
            <h3 class="text-2xl md:text-3xl font-bold text-yellow-100 group-hover:text-yellow-400 transition-colors duration-300">
                {project.title}
            </h3>
            {project.isTFG && (
                <span class="text-[10px] font-black bg-yellow-500/20 text-yellow-500 border border-yellow-500/50 px-2 py-0.5 rounded uppercase">
                    TFG
                </span>
            )}
        </div>

        <div class="flex flex-wrap gap-2">
            {project.tags.map(tag => (
                <span class="text-[11px] font-mono bg-zinc-800 text-zinc-400 px-2 py-1 rounded border border-zinc-700">
                    {tag}
                </span>
            ))}
        </div>

        <p class="text-slate-400 text-lg leading-relaxed text-pretty">
            {project.description}
        </p>

        <div class="flex gap-x-4 mt-2">
            {project.link && (
                <a
                    href={project.link}
                    target="_blank"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-zinc-950 font-bold rounded-xl hover:bg-yellow-400 transition-all duration-300 active:scale-95"
                >
                    <CVIcon class="size-4" />
                    Ver Proyecto
                </a>
            )}
            <!-- <button class="p-2.5 rounded-xl border border-white/10 text-white hover:bg-white/5 transition-all">
                <GithubIcon class="size-6" />
            </button> -->
        </div>
    </div>

    <div class="w-full md:w-1/2 overflow-hidden rounded-2xl border border-white/10 bg-zinc-900 group">
        <div class="relative overflow-hidden aspect-video">
            <Image
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 group-hover:rotate-2"
                src={project.image}
                alt={`Screenshot de ${project.title}`}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
    </div>
</article>

<style>
    /* Efecto de resplandor sutil detrás de la tarjeta al hacer hover */
    article::before {
        content: "";
        position: absolute;
        inset: -20px;
        background: radial-gradient(circle at center, rgba(234, 179, 8, 0.05) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.5s ease;
        z-index: -1;
    }
    article:hover::before {
        opacity: 1;
    }
</style>